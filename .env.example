# Copy to .env at repo root and fill in real values.
# Used by code_rh_and_reddit_toxic/ (see its README.md for details).

# Required for all code_rh_and_reddit_toxic runs (openweights provisions/terminates RunPod GPUs)
HF_ORG=
HF_TOKEN=
OPENWEIGHTS_API_KEY=

# Required if using the Reddit CMV pipeline (realistic_dataset/); otherwise set to a placeholder
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional — only needed if routing OpenAI-compatible calls through OpenRouter
OPENAI_BASE_URL=
OPENROUTER_API_KEY=
